# Claude Code Account Switcher — zsh integration
# Generated by: eval "$(claude-acc init zsh)"

__claude_acc_activate() {
    eval "$('__CLAUDE_ACC_BIN__' activate --shell posix)"
}

_claude_chpwd_hook() {
    __claude_acc_activate
}

autoload -Uz add-zsh-hook
add-zsh-hook chpwd _claude_chpwd_hook

# Activate for current directory on shell startup
__claude_acc_activate

# Completions
_claude_acc_completion() {
    local -a subcmds accounts
    subcmds=(
        'list:List accounts'
        'add:Add account'
        'login:Re-login to account'
        'remove:Remove account'
        'default:Show/set default account'
        'reset:Reset default'
        'link:Link account to directory'
        'unlink:Unlink directory'
        'links:Show all links'
        'status:Current account info'
        'run:Run claude under a specific account'
    )
    if (( CURRENT == 2 )); then
        _describe 'command' subcmds
    elif (( CURRENT == 3 )); then
        case "${words[2]}" in
            login|remove|run)
                accounts=(${(f)"$('__CLAUDE_ACC_BIN__' completions accounts)"})
                _describe 'account' accounts
                ;;
            default|link)
                accounts=('default' ${(f)"$('__CLAUDE_ACC_BIN__' completions accounts)"})
                _describe 'account' accounts
                ;;
        esac
    fi
}
compdef _claude_acc_completion claude-acc
